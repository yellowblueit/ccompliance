{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploys CCompliance on Azure App Service with Table Storage and Key Vault."
  },
  "parameters": {
    "appName": {
      "type": "string",
      "metadata": { "description": "Name for the Web App (must be globally unique)." },
      "minLength": 3,
      "maxLength": 40
    },
    "skuName": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": ["B1", "B2", "B3", "S1", "S2", "S3", "P1v3", "P2v3", "P3v3"],
      "metadata": { "description": "App Service Plan pricing tier." }
    },
    "adminUsername": {
      "type": "string",
      "metadata": { "description": "Username for the initial Super Admin local account." },
      "minLength": 3
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": { "description": "Password for the initial Super Admin local account." },
      "minLength": 8
    }
  },
  "variables": {
    "planName": "[concat(parameters('appName'), '-plan')]",
    "storageName": "[concat(replace(toLower(parameters('appName')), '-', ''), 'stg')]",
    "vaultName": "[concat(parameters('appName'), '-kv')]",
    "storageAccountId": "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[variables('storageName')]",
      "location": "[resourceGroup().location]",
      "kind": "StorageV2",
      "sku": { "name": "Standard_LRS" },
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('vaultName')]",
      "location": "[resourceGroup().location]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('appName'))]"
      ],
      "properties": {
        "sku": { "family": "A", "name": "standard" },
        "tenantId": "[subscription().tenantId]",
        "enabledForDeployment": false,
        "enabledForTemplateDeployment": false,
        "enableRbacAuthorization": false,
        "accessPolicies": [
          {
            "tenantId": "[subscription().tenantId]",
            "objectId": "[reference(resourceId('Microsoft.Web/sites', parameters('appName')), '2023-01-01', 'Full').identity.principalId]",
            "permissions": {
              "secrets": ["get", "list", "set"]
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[concat(variables('vaultName'), '/AzureStorage')]",
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('vaultName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]"
      ],
      "properties": {
        "value": "[concat('DefaultEndpointsProtocol=https;AccountName=', variables('storageName'), ';AccountKey=', listKeys(variables('storageAccountId'), '2023-01-01').keys[0].value, ';EndpointSuffix=core.windows.net')]"
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-01-01",
      "name": "[variables('planName')]",
      "location": "[resourceGroup().location]",
      "kind": "linux",
      "sku": { "name": "[parameters('skuName')]" },
      "properties": { "reserved": true }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-01-01",
      "name": "[parameters('appName')]",
      "location": "[resourceGroup().location]",
      "kind": "app,linux",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]"
      ],
      "identity": { "type": "SystemAssigned" },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "PYTHON|3.12",
          "appCommandLine": "startup.sh",
          "alwaysOn": true,
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "appSettings": [
            { "name": "ADMIN_USERNAME", "value": "[parameters('adminUsername')]" },
            { "name": "ADMIN_PASSWORD", "value": "[parameters('adminPassword')]" },
            { "name": "AzureWebJobsStorage", "value": "[concat('DefaultEndpointsProtocol=https;AccountName=', variables('storageName'), ';AccountKey=', listKeys(variables('storageAccountId'), '2023-01-01').keys[0].value, ';EndpointSuffix=core.windows.net')]" },
            { "name": "CREDENTIAL_STORAGE", "value": "keyvault" },
            { "name": "KEYVAULT_URL", "value": "[concat('https://', variables('vaultName'), '.vault.azure.net/')]" },
            { "name": "SCM_DO_BUILD_DURING_DEPLOYMENT", "value": "true" },
            { "name": "WEBSITE_HTTPLOGGING_RETENTION_DAYS", "value": "3" }
          ]
        }
      }
    }
  ],
  "outputs": {
    "appUrl": {
      "type": "string",
      "value": "[concat('https://', parameters('appName'), '.azurewebsites.net')]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[variables('vaultName')]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[variables('storageName')]"
    }
  }
}
