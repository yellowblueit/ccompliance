# Entra ID Authentication (REQUIRED - never stored in config.json)
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=
ENTRA_REDIRECT_URI=http://localhost:5000/getAToken
FLASK_SECRET_KEY=

# Credential storage: "local" (config.json) or "keyvault" (Azure Key Vault)
CREDENTIAL_STORAGE=local
KEYVAULT_URL=

# These CAN be set here OR in the Settings UI (config.json)
ANTHROPIC_COMPLIANCE_ACCESS_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
COMPLIANCE_MAILBOX=
COMPLIANCE_FOLDER_NAME=Claude AI Compliance
AzureWebJobsStorage=
ACTIVITY_BATCH_SIZE=500
CHAT_BATCH_SIZE=100
INGEST_CHAT_CONTENT=true
SYNC_SCHEDULE_CRON=*/15 * * * *
SYNC_ENABLED=false
